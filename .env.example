# ============================================================
# MAXY — contoh konfigurasi environment
# Salin file ini menjadi  .env  lalu isi sesuai kebutuhan.
# Semua nilai punya default aman untuk pengembangan lokal,
# jadi MAXY tetap jalan walau .env kosong (mode demo/lokal).
# ============================================================

# --- Identitas & jaringan ---------------------------------------------------
# Domain publik portal MAXY. Dipakai untuk membentuk tautan asesmen kandidat.
PUBLIC_BASE_URL=http://localhost:5050
SECRET_KEY=ganti-dengan-string-acak-panjang

# --- AI (Claude) ------------------------------------------------------------
# Tanpa key, MAXY tetap berjalan memakai fallback heuristik (skor & ringkasan
# sederhana). Untuk hasil terbaik (ekstraksi CV, analisis video, CAPTCHA), isi:
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_VISION_MODEL=claude-sonnet-4-6

# --- Sumber data: crewing.lintasmaritim.com ---------------------------------
# MAXY tidak menggantikan website pendaftaran klien. Data pendaftar ditarik
# dari sana lewat salah satu cara berikut:
#
# (A) PUSH (disarankan) — minta tim crewing kirim webhook tiap ada pendaftar:
#     POST {PUBLIC_BASE_URL}/webhook/crewing   header: X-Webhook-Secret: <secret>
WEBHOOK_SECRET=ganti-dengan-secret-webhook
#
# (B) PULL — MAXY menarik berkala dari endpoint daftar pendaftar crewing:
CREWING_POLL_URL=
CREWING_API_KEY=
CREWING_SESSION_COOKIE=
CREWING_POLL_INTERVAL=300

# --- Verifikasi sertifikat pelaut (RPA ke pelaut.dephub.go.id) --------------
# Hanya aktifkan bila server BISA mengakses pelaut.dephub.go.id dan Playwright
# Chromium sudah terpasang (playwright install chromium). Verifikasi memakai
# Claude Vision untuk membaca CAPTCHA.
ENABLE_CERT_VERIFY=false

# --- Tes DISC/MBTI & IQ (back office) — PLATFORM EKSTERNAL ------------------
# Tes dikerjakan kandidat di platform pihak ketiga (bukan di portal MAXY).
#   TEST_RESULT_MODE=upload  -> kandidat mengunggah berkas hasil ke MAXY (default)
#   TEST_RESULT_MODE=api     -> MAXY menarik hasil otomatis dari API provider
# Untuk mode "api", isi TEST_PROVIDER + URL + TOKEN di bawah.
TEST_RESULT_MODE=upload
TEST_PROVIDER=none
TEST_PROVIDER_API_URL=
TEST_PROVIDER_API_TOKEN=
# Tautan tes yang dibuka kandidat (ganti sesuai vendor tes Anda):
DISC_TEST_URL=https://www.123test.com/disc-personality-test/
IQ_TEST_URL=https://test.mensa.no/

# --- Notifikasi: Email (SMTP) -----------------------------------------------
# Kosongkan untuk mode log (link/notifikasi hanya dicetak ke konsol server).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=recruitment@lintasmaritim.com

# --- Notifikasi: WhatsApp ----------------------------------------------------
# WA_PROVIDER: none | fonnte | generic
WA_PROVIDER=none
WA_API_URL=
WA_API_TOKEN=

# --- Transkripsi video (Speech-to-Text) -------------------------------------
# STT_PROVIDER: stub | openai | groq | local
#   stub   : transcript contoh (default; tanpa biaya, untuk demo)
#   openai : OpenAI Whisper API   (butuh OPENAI_API_KEY)
#   groq   : Groq Whisper API     (butuh GROQ_API_KEY)
#   local  : faster-whisper lokal (butuh paket faster-whisper)
STT_PROVIDER=stub
OPENAI_API_KEY=
GROQ_API_KEY=
WHISPER_MODEL=whisper-1

# --- Penyimpanan & retensi --------------------------------------------------
# DB_PATH=/path/ke/maxy.db
# STORAGE_DIR=/path/ke/storage
VIDEO_RETENTION_DAYS=90

# --- Identitas perusahaan (untuk kontrak PKWT) ------------------------------
COMPANY_LEGAL_NAME=PT Lintas Maritim Indonesia
COMPANY_SHORT_NAME=Lintas Maritim
COMPANY_CITY=Jakarta
